generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  uid       String   @id
  updatedAt DateTime @updatedAt
  stats     UserBannerStat[]
}

model UserBannerStat {
  uid        String
  bannerId   String // 'standard', 'special', 'special_banner_01' и т.д.
  
  totalPulls Int @default(0)
  lastUpdate DateTime @default(now())

  total6     Int @default(0)
  sumPity6   Int @default(0)
  
  total5     Int @default(0)
  sumPity5   Int @default(0)

  won5050    Int @default(0)
  total5050  Int @default(0)

  lastProcessedPullTime BigInt @default(0)

  user       User @relation(fields: [uid], references: [uid])

  @@id([uid, bannerId])
  
  @@index([bannerId, totalPulls]) 
  @@index([bannerId, sumPity6])
}

model ImportError {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  
  url       String
  error     String
  stack     String?
  serverId  String?
  solved    Boolean  @default(false)
}

model GlobalBannerStats {
  bannerId      String   @id
  totalPulls    BigInt   @default(0)
  totalUsers    Int      @default(0)
  
  total6        Int      @default(0)
  total5        Int      @default(0)
  
  limitedCount  Int      @default(0)
  lost5050      Int      @default(0)
  
  updatedAt     DateTime @updatedAt
}

model GlobalTimeline {
  bannerId String
  date     String // формат "YYYY-MM-DD"
  pulls    Int    @default(0)

  @@id([bannerId, date])
}

model GlobalPityDistribution {
  bannerId  String
  pity      Int
  rarity    Int
  count     Int @default(0)

  @@id([bannerId, rarity, pity])
}

model GlobalItemStats {
  bannerId String
  itemName String
  rarity   Int
  count    Int    @default(0)

  @@id([bannerId, itemName])
}

model UserAccount {
  id                Int                  @id @default(autoincrement())
  firebase_uid      String               @unique
  created_at        DateTime             @default(now())
  updated_at        DateTime             @default(now()) @updatedAt
  picture           String?              @unique
  name              String?
  avatar_strike     Int                  @default(0)
  upload_count      Int                  @default(0)
  last_upload_reset DateTime             @default(now())
  is_private        Int                  @default(0)
  
  details           UserAccountDetails[]

  @@map("user_account")
}

model UserAccountDetails {
  id           Int               @id @default(autoincrement())
  user_id      Int
  game_uid     String            @unique
  account_info String            // TEXT / JSON payload
  
  user         UserAccount       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  leaderboards UserLeaderboard[]

  @@map("user_account_details")
}

model UserLeaderboard {
  id               Int                @id @default(autoincrement())
  game_uid         String
  event_type       String             // "contract" or "monument"
  clear_time       Float
  leaderboard_info String             // JSON data (characters used, levels, etc.)

  account_detail   UserAccountDetails @relation(fields: [game_uid], references: [game_uid], onDelete: Cascade)

  @@map("user_leaderboard")
}

